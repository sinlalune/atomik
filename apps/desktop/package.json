{
  "name": "atomik-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Atomik desktop shell — Electron main/preload/renderer split per docs/bedrock/12_12-electron-mvp.md and 13_13-electron-security.md. Deliberately CommonJS (no \"type\": \"module\"): sandboxed preload scripts require a CJS bundle.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "smoke": "electron-vite build && ATOMIK_SMOKE=1 electron .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "codemirror": "^6.0.2",
    "markdown-it": "^14.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
